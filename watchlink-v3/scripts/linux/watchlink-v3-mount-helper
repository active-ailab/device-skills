#!/usr/bin/env bash
set -euo pipefail

SAFE_MOUNT_ROOT="/mnt"

usage() {
  cat <<'USAGE'
Usage:
  watchlink-v3-mount-helper prepare-drvfs-mount --drive <LETTER> --mount-point <safe-mount-point> --owner <uid:gid|user:group>

Commands:
  prepare-drvfs-mount   Clean stale dedicated mount point, mount <LETTER>: via drvfs, then ensure the mount point is writable
USAGE
}

require_root() {
  if [[ "${EUID}" -ne 0 ]]; then
    echo "[ERR] watchlink-v3-mount-helper must run as root." >&2
    exit 100
  fi
}

validate_drive() {
  local drive="$1"
  [[ "$drive" =~ ^[A-Za-z]$ ]] || {
    echo "[ERR] drive must be a single letter, got: $drive" >&2
    exit 101
  }
}

validate_mount_point() {
  local drive_lower="$1"
  local mount_point="$2"
  local legacy="/mnt/${drive_lower}"
  local dedicated="${SAFE_MOUNT_ROOT}/${drive_lower}"
  [[ "$mount_point" == "$legacy" || "$mount_point" == "$dedicated" ]] || {
    echo "[ERR] mount point must be exactly $legacy or $dedicated, got: $mount_point" >&2
    exit 102
  }
}

validate_owner() {
  local owner="$1"
  [[ "$owner" =~ ^[0-9]+:[0-9]+$ || "$owner" =~ ^[A-Za-z_][A-Za-z0-9_-]*:[A-Za-z_][A-Za-z0-9_-]*$ ]] || {
    echo "[ERR] owner must look like uid:gid or user:group, got: $owner" >&2
    exit 103
  }
}

mount_is_active() {
  local mount_point="$1"
  /usr/bin/mountpoint -q "$mount_point" >/dev/null 2>&1 && return 0
  /usr/bin/findmnt -M "$mount_point" >/dev/null 2>&1 && return 0
  return 1
}

mount_is_usable() {
  local mount_point="$1"
  /usr/bin/ls -d "$mount_point" >/dev/null 2>&1
}

ensure_mount_writable() {
  local mount_point="$1"
  local owner="$2"

  if /usr/bin/chown "$owner" "$mount_point" >/dev/null 2>&1; then
    return 0
  fi

  if [[ -w "$mount_point" ]]; then
    return 0
  fi

  echo "[ERR] mount point is not writable and chown failed: $mount_point" >&2
  exit 106
}

detach_mount_layers() {
  local mount_point="$1"
  local attempts=0
  while mount_is_active "$mount_point"; do
    attempts=$((attempts + 1))
    if [[ "$attempts" -gt 8 ]]; then
      echo "[ERR] unable to fully detach stale mount layers at $mount_point" >&2
      exit 105
    fi
    /usr/bin/umount -l "$mount_point" >/dev/null 2>&1 || /usr/bin/umount "$mount_point"
  done
}

prepare_drvfs_mount() {
  local drive="$1"
  local mount_point="$2"
  local owner="$3"
  local drive_lower="${drive,,}"

  validate_drive "$drive"
  validate_mount_point "$drive_lower" "$mount_point"
  validate_owner "$owner"

  if mount_is_active "$mount_point"; then
    if mount_is_usable "$mount_point"; then
      ensure_mount_writable "$mount_point" "$owner"
      return 0
    fi

    detach_mount_layers "$mount_point"
  fi

  /usr/bin/mkdir -p "$mount_point"
  /usr/bin/mount -t drvfs "${drive^^}:" "$mount_point"
  ensure_mount_writable "$mount_point" "$owner"

  mount_is_active "$mount_point" || {
    echo "[ERR] drvfs mount did not become active at $mount_point" >&2
    exit 104
  }
}

require_root

[[ $# -ge 1 ]] || {
  usage
  exit 1
}

cmd="$1"
shift

case "$cmd" in
  prepare-drvfs-mount)
    drive=""
    mount_point=""
    owner=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --drive) drive="$2"; shift 2 ;;
        --mount-point) mount_point="$2"; shift 2 ;;
        --owner) owner="$2"; shift 2 ;;
        -h|--help) usage; exit 0 ;;
        *)
          echo "[ERR] Unknown arg: $1" >&2
          usage
          exit 1
          ;;
      esac
    done

    [[ -n "$drive" && -n "$mount_point" && -n "$owner" ]] || {
      echo "[ERR] --drive, --mount-point and --owner are required." >&2
      usage
      exit 1
    }
    prepare_drvfs_mount "$drive" "$mount_point" "$owner"
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    echo "[ERR] Unknown command: $cmd" >&2
    usage
    exit 1
    ;;
esac
